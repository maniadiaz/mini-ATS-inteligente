# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3105
BASE_URL=https://ats.tudominio.com

# ─── Security ─────────────────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ─── Database (MySQL) ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ats_db
USER_DB=ats_user
USER_PASSWORD_DB=

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID del plan de suscripcion mensual
STRIPE_PRICE_ID=price_...
# Price ID del paquete de CVs extra (pago unico)
STRIPE_PACK_PRICE_ID=price_...
# Cantidad de CVs que incluye el paquete extra
CV_PACK_QUANTITY=50
# Precio en MXN del paquete extra
CV_PACK_PRICE=299

# ─── Mail (SMTP) ──────────────────────────────────────────────────────────────
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USER=postmaster@mg.tudominio.com
MAIL_PASS=
SMTP_FROM=

# ─── Superadmin (seed inicial al primer arranque) ─────────────────────────────
SUPERADMIN_EMAIL=admin@tudominio.com
SUPERADMIN_PASSWORD=
SUPERADMIN_COMPANY_NAME=ServerControl
SUPERADMIN_NOMBRE=Super Admin

# ─── Plan (seed inicial) ──────────────────────────────────────────────────────
PLAN_NAME=ATS Pro
PLAN_PRICE=999

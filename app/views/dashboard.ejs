<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Mini ATS</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <header class="header">
            <h1>Mini ATS Inteligente</h1>
            <div class="header-actions">
                <span class="meta">Hola, <%= user %></span>
                <a href="/logout" class="btn btn-secondary btn-sm">Cerrar sesión</a>
            </div>
        </header>

        <div class="toolbar">
            <a href="/vacante/nueva" class="btn btn-primary">+ Nueva Vacante</a>
        </div>

        <h2>Vacantes activas</h2>
        <% if (vacantes.size > 0) { %>
        <div class="vacantes-list">
            <% for (const [id, v] of vacantes) { %>
            <div class="card">
                <div class="card-header">
                    <h3><a href="/vacante/<%= id %>/dashboard"><%= v.puesto %></a></h3>
                    <span class="badge badge-neutral"><%= v.postulaciones.length %> postulante(s)</span>
                </div>
                <p class="meta"><%= v.empresa %> &middot; <%= v.anios_exp %> años exp. &middot; Inglés: <%= v.ingles %></p>
                <p><%= v.descripcion.substring(0, 150) %><%= v.descripcion.length > 150 ? '...' : '' %></p>
                <div class="card-actions">
                    <a href="/vacante/<%= id %>/dashboard" class="btn btn-secondary btn-sm">Ver candidatos</a>
                </div>
            </div>
            <% } %>
        </div>
        <% } else { %>
        <p class="empty">No hay vacantes creadas aún. ¡Crea la primera!</p>
        <% } %>
    </div>
</body>
</html>
